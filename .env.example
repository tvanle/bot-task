# Discord Bot Token - Lấy từ https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Channel ID để gửi thông báo task (Right-click channel -> Copy ID)
NOTIFICATION_CHANNEL_ID=your_channel_id_here

# Thời gian nhắc nhở trước deadline (phút)
REMINDER_MINUTES_BEFORE=60

# ===== GITHUB WEBHOOK CONFIGURATION =====
# Secret để verify webhook (tạo random string, phải giống với GitHub webhook settings)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Channel ID để gửi thông báo GitHub (mặc định dùng NOTIFICATION_CHANNEL_ID)
GITHUB_CHANNEL_ID=your_github_channel_id_here

# Port cho webhook server (mặc định 8080)
WEBHOOK_PORT=8080
